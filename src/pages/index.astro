---
import DefaultLayout from '@layouts/DefaultLayout.astro'

import Hero from '@components/sections/Hero.astro'
import About from '@components/sections/About.astro'
import SocialProof from '@components/sections/SocialProof.astro'
import ServicesGrid from '@components/sections/ServicesGrid.astro'
import Investment from '@components/sections/Investment.astro'
import Process from '@components/sections/Process.astro'
import Portfolio from '@components/sections/Portfolio.astro'
import Testimonials from '@components/sections/Testimonials.astro'
---

<DefaultLayout
