---
import DefaultLayout from '@layouts/DefaultLayout.astro'
import { Link } from 'accessible-astro-components'
import speakerImage from '@assets/images/speaker.webp'
import { Mic, Download, Mail, Presentation } from '@lucide/astro'
import { getCollection } from 'astro:content'

const talks = await getCollection('talks')
const talksByYear = talks.reduce((acc, talk) => {
  const year = talk.data.date.getFullYear().toString()
  if (!acc[year]) acc[year] = []
  acc[year].push({ ...talk.data, slug: talk.slug })
  return acc
}, {})

const sortedYears = Object.keys(talksByYear).sort((a, b) => Number(b) - Number(a))

function formatDate(date: Date): string {
  return date
    .toLocaleDateString('en-US', {
      month: 'short',
      day: 'numeric',
      year: 'numeric',
    })
    .replace(',', '')
}

function getTypeIcon(type: string) {
  switch (type) {
    case 'keynote':
      return 'record_voice_over'
    case 'workshop':
      return 'groups'
    case 'talk':
      return 'chat'
    default:
      return 'event'
  }
}
---

<DefaultLayout title="Serviços - Bruno Pulis" useTitleTemplate={false}>
  <section class="bg-surface-container-lowest relative overflow-hidden px-8 py-24">
    <div class="container mx-auto grid items-center gap-12 md:grid-cols-2">
      <div class="z-10">
        <span class="architect-label mb-4 block uppercase">Palestrante e Especialista</span>
        <h1 class="text-brand-primary mb-6 text-4xl leading-tight font-bold md:text-7xl">
          Palestras e <span class="font-normal italic">Workshops</span>
        </h1>
        <p class="mb-10 max-w-2xl text-xl leading-relaxed font-normal">
          Compartilhando conhecimento sobre como construir uma web mais acessível e padronizada. Meu foco é
          <strong>acessibilidade prática</strong>, padrões WCAG e sistemas de design inclusivo.
        </p>
        <div class="flex gap-4">
          <Link
            class="bg-brand-primary focus:ring-brand-vista-blue rounded-lg px-8 py-4 text-lg font-bold text-white no-underline transition-all outline-none hover:opacity-90 focus:ring-2"
            href="#proximas"
          >
            Ver Agenda
          </Link>
        </div>
      </div>
      <div class="relative hidden md:block">
        <div
          class="bg-surface-container-high aspect-square overflow-hidden rounded-lg grayscale transition-all duration-700 hover:grayscale-0"
        >
          <img
            alt="Bruno Pulis em uma palestra sobre acessibilidade"
            class="h-full w-full object-cover"
            src={speakerImage.src}
          />
        </div>
      </div>
    </div>
    <div class="bg-surface-container-low absolute top-0 right-0 -z-0 h-full w-1/3"></div>
  </section>

  <section class="bg-surface-container-low px-8 py-24" id="proximas">
    <div class="mx-auto max-w-7xl">
      <div class="border-outline-variant mb-12 flex flex-col items-baseline justify-between border-b pb-8 md:flex-row">
        <div>
          <span class="architect-label text-brand-secondary font-bold uppercase">Agenda</span>
          <h2 class="text-brand-primary mt-2 text-4xl font-bold">Palestras Agendadas</h2>
        </div>
        <p class="text-on-surface-variant mt-4 font-serif italic md:mt-0">Sessões confirmadas para este ano.</p>
      </div>
      <div class="space-y-4">
        <div
          class="bg-surface-container-lowest flex flex-col items-center gap-8 rounded-lg p-6 transition-transform hover:-translate-y-1 md:flex-row md:p-8"
        >
          <div
            class="border-outline-variant flex min-w-[120px] flex-col items-center justify-center border-r-0 pr-0 text-center md:border-r md:pr-8"
          >
            <span class="text-brand-blood-red font-serif text-4xl font-bold">15</span>
            <span class="text-on-surface-variant text-xs font-bold tracking-widest uppercase">OUT 2024</span>
          </div>
          <div class="flex-grow">
            <h3 class="text-on-surface mb-1 text-2xl font-bold">Accessibility First: O Futuro do Frontend</h3>
            <p class="text-on-surface-variant font-light">FrontIn Sampa • São Paulo, Brasil</p>
          </div>
          <a
            class="group text-brand-blood-red flex items-center gap-2 text-sm font-bold tracking-widest uppercase transition-all hover:gap-4"
            href="#"
          >
            DETALHES DO EVENTO
            <span aria-hidden="true" class="text-brand-vista-blue material-symbols-outlined">arrow_forward</span>
          </a>
        </div>
        <!-- Agendada Item -->
        <div
          class="bg-surface-container-lowest flex flex-col items-center gap-8 rounded-lg p-6 transition-transform hover:-translate-y-1 md:flex-row md:p-8"
        >
          <div
            class="border-outline-variant flex min-w-30 flex-col items-center justify-center border-r-0 pr-0 text-center md:border-r md:pr-8"
          >
            <span class="text-brand-blood-red font-serif text-4xl font-bold">02</span>
            <span class="text-on-surface-variant text-xs font-bold tracking-widest uppercase">NOV 2024</span>
          </div>
          <div class="grow">
            <h3 class="text-on-surface mb-1 text-2xl font-bold">Workshop: WCAG 2.2 de A a Z</h3>
            <p class="text-on-surface-variant font-light">DevFest NE • Salvador, Brasil</p>
          </div>
          <a
            class="group text-brand-blood-red flex items-center gap-2 text-sm font-bold tracking-widest uppercase transition-all hover:gap-4"
            href="#"
          >
            GARANTIR VAGA
            <span aria-hidden="true" class="text-brand-vista-blue material-symbols-outlined">arrow_forward</span>
          </a>
        </div>
      </div>
    </div>
  </section>

  <section class="mb-20">
    <div class="container">
      {
        sortedYears.map((year) => (
          <div class="border-border-dark mb-12">
            <div class="mb-8 flex items-baseline justify-between border-b pb-4">
              <h2 class="text-brand-secondary text-3xl font-bold tracking-tight">{year}</h2>
              <span class="text-sm">
                {talksByYear[year].length} {talksByYear[year].length === 1 ? 'palestra' : 'palestras'}
              </span>
            </div>
            <div class="grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3">
              {talksByYear[year].map((talk) => (
                <div class="group border-brand-primary cursor-default border bg-white/5 p-8 transition-all hover:bg-white/10">
                  <div class="mb-4 flex items-center justify-between">
                    <span class="text-primary material-symbols-outlined text-3xl">{getTypeIcon(talk.type)}</span>
                    <span class="text-[10px] font-bold tracking-widest text-gray-500 uppercase">
                      {formatDate(talk.date)}
                    </span>
                  </div>
                  <div class="flex-1">
                    <h3 class="group-hover:text-primary text-xl leading-tight font-bold text-white transition-colors">
                      {talk.title}
                    </h3>
                    <p class="mt-3 text-sm font-medium text-gray-400 italic">{talk.event}</p>
                    <div class="mt-4 flex items-center gap-1.5 text-xs text-gray-500">
                      <span class="material-symbols-outlined text-sm">location_on</span>
                      <span>{talk.location}</span>
                    </div>
                  </div>
                  <div class="mt-8 flex flex-wrap gap-3">
                    {talk.links?.slides && (
                      <a
                        class="text-primary flex items-center gap-2 text-xs font-bold hover:underline"
                        href={talk.links.slides}
                        target="_blank"
                        rel="noopener noreferrer"
                      >
                        <span class="material-symbols-outlined text-base">present_to_all</span>
                        Slides
                      </a>
                    )}
                    {talk.links?.video && (
                      <a
                        class="text-primary flex items-center gap-2 text-xs font-bold hover:underline"
                        href={talk.links.video}
                        target="_blank"
                        rel="noopener noreferrer"
                      >
                        <span class="material-symbols-outlined text-base">play_circle</span>
                        Vídeo
                      </a>
                    )}
                    {talk.links?.recursos && (
                      <a
                        class="text-primary flex items-center gap-2 text-xs font-bold hover:underline"
                        href={talk.links.recursos}
                        target="_blank"
                        rel="noopener noreferrer"
                      >
                        <span class="material-symbols-outlined text-base">code</span>
                        Recursos
                      </a>
                    )}
                  </div>
                </div>
              ))}
            </div>
          </div>
        ))
      }
    </div>
  </section>

  <section class="bg-brand-primary relative overflow-hidden px-8 py-24 text-white" id="contact">
    <div class="relative z-10 mx-auto max-w-4xl text-center">
      <span class="text-brand-secondary mb-6 block font-bold uppercase">Contato para eventos</span>
      <h2 class="mb-8 text-4xl leading-tight font-bold md:text-6xl">Interessado em me ter palestrando?</h2>
      <p class="mx-auto mb-12 max-w-2xl text-xl">
        Atualmente estou aceitando convites para palestras em 2026. Adoro compartilhar minha paixão por acessibilidade
        em conferências, meetups e eventos internos de empresas.
      </p>
      <div class="flex flex-col justify-center gap-6 sm:flex-row">
        <a
          class="hover:bg-brand-outline text-brand-blood-red flex items-center justify-center gap-3 rounded-lg bg-white px-10 py-5 text-lg font-bold transition-all outline-none hover:text-white focus:ring-2 focus:ring-white"
          href="mailto:contato@brunopulis.com"
        >
          <Mail class="text-3xl" aria-hidden="true" />
          Enviar e-mail
        </a>
        <a
          class="flex items-center justify-center gap-3 rounded-lg border border-white/20 px-10 py-5 text-lg font-bold transition-all hover:bg-white/10"
          href="#"
        >
          <Download aria-hidden="true" class="text-3xl" />
          Media Kit
        </a>
      </div>
    </div>
    <!-- Abstract background element -->
    <div class="bg-brand-blood-red/10 absolute top-0 right-0 -mt-48 -mr-48 h-96 w-96 rounded-full blur-3xl"></div>
    <div class="bg-brand-vista-blue/5 absolute bottom-0 left-0 -mb-48 -ml-48 h-96 w-96 rounded-full blur-3xl"></div>
  </section>
</DefaultLayout>
