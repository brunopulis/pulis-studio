---
import DefaultLayout from '@layouts/DefaultLayout.astro'
import { Link } from 'accessible-astro-components'
import Feature from '@components/ui/Feature.astro'
import PageHeader from '@components/ui/PageHeader.astro'
import { ChevronRight } from '@lucide/astro'
---

<DefaultLayout title="Serviços - Bruno Pulis" useTitleTemplate={false}>
  <PageHeader
    title="Serviços"
    subtitle=" Ajudo organizações a tornarem seus produtos digitais, processos e cultura mais acessíveis e usáveis."
    class="bg-rosewood-950 text-white"
  />

  <div class="container space-y-24">
    <section>
      <div class="my-10 flex items-center gap-4">
        <span class="text-rosewood-950 text-xs font-bold tracking-[0.2em] uppercase">01</span>
        <h2 class="text-rosewood-950 text-2xl font-bold tracking-widest uppercase">Diagnóstico</h2>
        <div class="dark:bg-border-dark h-px grow bg-slate-200"></div>
      </div>
      <div class="grid gap-6 md:grid-cols-2">
        <Feature icon="lucide:fast-forward" title="Avaliação de Acessibilidade">
          <p class="text-secondary mb-6 text-sm leading-relaxed">
            Descubra exatamente onde você está. Diagnóstico focado que revela oportunidades rápidas de melhoria para seu
            produto digital.
          </p>
          <Link
            class="text-rosewood-950 mt-auto flex items-center gap-2 pt-4 text-xs font-bold tracking-widest uppercase"
            href="/servicos/avaliacao-acessibilidade"
          >
            <span>Ver detalhes</span>
            <ChevronRight class="text-rosewood-950 text-sm!" aria-hidden="true" />
          </Link>
        </Feature>
        <Feature icon="lucide:shield-check" title="Auditoria de Acessibilidade">
          <p class="text-secondary mb-6 text-sm leading-relaxed">
            Análise profunda e estruturada que mapeia o caminho completo para conformidade com padrões WCAG
            internacionais.
          </p>
          <Link
            class="text-rosewood-950 mt-auto flex items-center gap-2 pt-4 text-xs font-bold tracking-widest uppercase"
          >
            <span>Ver detalhes</span>
            <ChevronRight class="text-rosewood-950 text-sm!" aria-hidden="true" />
          </Link>
        </Feature>
      </div>
    </section>

    <section>
      <div class="my-10 flex items-center gap-4">
        <span class="text-rosewood-950 text-xs font-bold tracking-[0.2em] uppercase">02</span>
        <h2 class="text-rosewood-950 text-2xl font-bold tracking-widest uppercase">Execução</h2>
        <div class="dark:bg-border-dark h-px grow bg-slate-200"></div>
      </div>

      <div class="grid gap-6 md:grid-cols-2">
        <Feature icon="lucide:files" title="Remediação de documentos">
          <p class="text-secondary mb-6 text-sm leading-relaxed">
            Transformação de PDFs e documentos Office em arquivos totalmente navegáveis e acessíveis.
          </p>
          <Link
            class="text-rosewood-950 mt-auto flex items-center gap-2 pt-4 text-xs font-bold tracking-widest uppercase"
          >
            <span>Ver detalhes</span>
            <ChevronRight class="text-rosewood-950 text-sm!" aria-hidden="true" />
          </Link>
        </Feature>

        <Feature icon="lucide:code" title="Construção de Sites Acessíveis">
          <p class="text-secondary mb-6 text-sm leading-relaxed">
            Sites rápidos, intuitivos e construídos desde o início para incluir todos os usuários e tecnologias
            assistivas.
          </p>
          <Link
            class="text-rosewood-950 mt-auto flex items-center gap-2 pt-4 text-xs font-bold tracking-widest uppercase"
          >
            <span>Ver detalhes</span>
            <ChevronRight class="text-rosewood-950 text-sm!" aria-hidden="true" />
          </Link>
        </Feature>
      </div>
    </section>

    <section>
      <div class="my-10 flex items-center gap-4">
        <span class="text-rosewood-950 text-xs font-bold tracking-[0.2em] uppercase">03</span>
        <h2 class="text-rosewood-950 text-2xl font-bold tracking-widest uppercase">Educação e Cultura</h2>
        <div class="dark:bg-border-dark h-px grow bg-slate-200"></div>
      </div>

      <div class="grid gap-6 md:grid-cols-2">
        <Feature icon="lucide:graduation-cap" title="Treinamentos e Workshops">
          <p class="text-secondary mb-6 text-sm leading-relaxed">
            Capacitação prática para desenvolvedores, designers e gestores sobre práticas modernas de inclusão.
          </p>
          <Link
            class="text-rosewood-950 mt-auto flex items-center gap-2 pt-4 text-xs font-bold tracking-widest uppercase"
          >
            <span>Ver detalhes</span>
            <ChevronRight class="text-rosewood-950 text-sm!" aria-hidden="true" />
          </Link>
        </Feature>

        <Feature icon="lucide:speech" title="Palestras e Apresentaçõe">
          <p class="text-secondary mb-6 text-sm leading-relaxed">
            Inspire sua organização e mostre por que a acessibilidade é essencial para negócios e para a sociedade.
          </p>
          <Link
            class="text-rosewood-950 mt-auto flex items-center gap-2 pt-4 text-xs font-bold tracking-widest uppercase"
          >
            <span>Ver detalhes</span>
            <ChevronRight class="text-rosewood-950 text-sm!" aria-hidden="true" />
          </Link>
        </Feature>
      </div>
    </section>

    <section>
      <div class="my-10 flex items-center gap-4">
        <span class="text-rosewood-950 text-xs font-bold tracking-[0.2em] uppercase">04</span>
        <h2 class="text-rosewood-950 text-2xl font-bold tracking-widest uppercase">Acompanhamento estratégico</h2>
        <div class="dark:bg-border-dark h-px grow bg-slate-200"></div>
      </div>

      <div class="grid gap-6 md:grid-cols-3">
        <Feature icon="lucide:graduation-cap" title="Coaching e Mentoria">
          <p class="text-secondary mb-6 text-sm leading-relaxed">
            Acessibilidade como jornada contínua, com acompanhamento próximo e personalizado para líderes técnicos.
            <Link
              class="text-rosewood-950 mt-auto flex items-center gap-2 pt-4 text-xs font-bold tracking-widest uppercase"
            >
              <span>Ver detalhes</span>
              <ChevronRight class="text-rosewood-950 text-sm!" aria-hidden="true" />
            </Link>
          </p>
        </Feature>

        <Feature icon="lucide:shield-check" title="Consultoria selo CPA">
          <p class="text-secondary mb-6 text-sm leading-relaxed">
            Preparação técnica completa para obtenção do Selo de Acessibilidade Digital da CPA/SMPED.
          </p>
          <Link
            class="text-rosewood-950 mt-auto flex items-center gap-2 pt-4 text-xs font-bold tracking-widest uppercase"
          >
            <span>Ver detalhes</span>
            <ChevronRight class="text-rosewood-950 text-sm!" aria-hidden="true" />
          </Link>
        </Feature>

        <Feature icon="lucide:handshake" title="Consultoria Estratégica">
          <p class="text-secondary mb-6 text-sm leading-relaxed">
            Implemento acessibilidade como parte da estratégia do negócio, não como uma correção tardia de código.
          </p>
          <Link
            class="text-rosewood-950 mt-auto flex items-center gap-2 pt-4 text-xs font-bold tracking-widest uppercase"
          >
            <span>Ver detalhes</span>
            <ChevronRight class="text-rosewood-950 text-sm!" aria-hidden="true" />
          </Link>
        </Feature>
      </div>
    </section>
  </div>

  <section class="container my-32 space-y-24">
    <div
      class="bg-rosewood-950 dark:bg-card-dark dark:border-border-dark relative overflow-hidden rounded-3xl border border-gray-200 p-12 text-center"
    >
      <div class="bg-primary/20 absolute -top-24 -left-24 h-64 w-64 rounded-full blur-3xl"></div>
      <div class="bg-accent-blue/10 absolute -right-24 -bottom-24 h-64 w-64 rounded-full blur-3xl"></div>
      <h2 class="relative z-10 mb-6 text-4xl font-bold text-white">Ainda em dúvida?</h2>
      <p class="relative z-10 mx-auto mb-10 max-w-2xl text-lg text-white">
        A avaliação de acessibilidade é o melhor primeiro passo para entender o que realmente importa agora. Vamos
        conversar sobre como elevar o nível do seu produto?
      </p>
      <Link
        isButton
        class="bg-primary hover:bg-opacity-90 shadow-primary/20 relative z-10 transform rounded-xl px-10 py-4 text-lg font-bold text-white shadow-xl transition-all hover:scale-105"
      >
        Solicitar avaliação de acessibilidade
      </Link>
    </div>
  </section>
</DefaultLayout>
