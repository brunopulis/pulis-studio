---
import { ChevronRight } from '@lucide/astro'
import { Card, Link } from 'accessible-astro-components'
import { Icon } from 'astro-icon/components'
import { getCollection } from 'astro:content'

// Import images directly for optimization
import projectImage1 from '@assets/images/projects/project-image-1.png'
import projectImage2 from '@assets/images/projects/project-image-2.png'
import projectImage3 from '@assets/images/projects/project-image-3.png'

/**
 * FeaturedProjects Component
 *
 * @description A component that displays featured projects from Astro Content Collections
 */
interface Props {
  /**
   * Additional classes to apply to the section
   */
  class?: string
  /**
   * The number of projects to display
   * @default 3
   */
  limit?: number
  /**
   * The title for the section
   * @default "Projetos em destaque"
   */
  title?: string
}

const { class: className, limit = 3, title = 'Projetos em destaque' } = Astro.props

// Get projects from content collection
const projects = await getCollection('projects')
const projectImages = [projectImage1, projectImage2, projectImage3]

// Limit projects and add featured images
const featuredProjects = projects.slice(0, limit).map((project, index) => ({
  ...project,
  featuredImage: projectImages[index % projectImages.length],
}))
---

<section class="bg-brand-primary px-8 py-24">
  <div class="mx-auto max-w-7xl">
    <div class="mb-16 flex flex-col items-end justify-between gap-8 md:flex-row">
      <div class="max-w-xl">
        <p class="text-brand-secondary mb-4 text-sm font-bold tracking-[0.15em] uppercase">RESULTADOS</p>
        <h2 class="font-serif text-4xl text-white">
          Projetos que definem o <span class="text-brand-red italic">padrão.</span>
        </h2>
      </div>
      <a class="group text-brand-white flex items-center gap-2 font-bold" href="#">
        Ver portfólio completo
        <ChevronRight class="transition-transform group-hover:translate-x-1" aria-hidden="true" />
      </a>
    </div>

    <div class="grid grid-cols-1 gap-12 md:grid-cols-2 lg:grid-cols-3">
      {
        featuredProjects.map((project) => (
          <Card
            imageComponent={project.featuredImage}
            url={'/portfolio/' + project.id}
            class="bg-white"
            headingLevel="h2"
            title={project.data.title}
            footer={'Autor: ' + project.data.author}
          >
            {project.data.description}
          </Card>
        ))
      }
    </div>
    <div class="mx-auto mt-12 justify-center">
      <Link href="/portfolio/" isButton animateOnHover animationType="nudge">
        Ver todos os projetos
        <Icon aria-hidden="true" name="lucide:arrow-right" size="1.5rem" />
      </Link>
    </div>
  </div>
</section>
