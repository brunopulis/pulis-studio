---
import { Avatar } from 'accessible-astro-components'
import testimonialsData from '@data/testimonials.json'

interface Testimonial {
  id: number
  name: string
  role: string
  content: string
  avatar: string
}
---

<section class="bg-white py-20">
  <div class="mx-auto max-w-7xl px-8">
    <div class="mx-auto mb-16 max-w-2xl text-center">
      <p class="text-portage-500 mb-4 text-sm font-bold tracking-[0.15em] uppercase">O que dizem</p>
      <h2 class="font-serif text-4xl">Depoimentos</h2>
    </div>
    <div class="grid grid-cols-1 gap-8 md:grid-cols-2">
      {
        testimonialsData.map((testimonial: Testimonial) => (
          <div class="group cursor-default rounded-xl border border-neutral-700/50 bg-white/5 p-8 transition-all hover:bg-white/10">
            <p class="mb-6 text-lg text-neutral-700">{testimonial.content}</p>
            <div class="flex items-center gap-4">
              <Avatar
                class="flex h-12 w-12 items-center justify-center rounded-full bg-neutral-200"
                size="sm"
                label="Unknown user"
              />
              <div>
                <p class="font-bold">{testimonial.name}</p>
                <p class="text-sm text-neutral-500">{testimonial.role}</p>
              </div>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
