---
import { Heading, Link } from 'accessible-astro-components'
import { Icon } from 'astro-icon/components'

/**
 * CallToAction Component
 *
 * @description A prominent call-to-action section with a title and link
 */
interface Props {
  /**
   * The title text to display
   * @default "Get this theme on GitHub"
   */
  title?: string
  /**
   * The URL the button should link to
   * @default "https://github.com/incluud/accessible-astro-starter"
   */
  link?: string
  /**
   * The text to display on the button
   * @default "Get Started"
   */
  linkText?: string
}

const {
  title = 'Pronto para tornar seu produto',
  link = 'https://github.com/incluud/accessible-astro-starter',
  linkText = ' Me manda um e-mail. Sem formulário, sem funil de vendas — só uma conversa direta sobre como posso ajudar. ',
} = Astro.props
---

<section class="bg-aztec-900 px-8 py-32 text-white">
  <div class="mx-auto max-w-7xl text-center">
    <p class="text-portage-500 mb-6 text-sm font-bold tracking-[0.15em] uppercase">Vamos dialogar</p>
    <Heading level="h2" class="mx-auto mb-12 max-w-4xl text-5xl leading-tight md:text-6xl">
      {title}
      <span class="text-portage-500">verdadeiramente</span> universal?
    </Heading>
    <Link
      isButton
      class="border-brand-red hover:text-vista-blue inline-flex items-center gap-4 border-b-2 pb-2 font-serif text-3xl text-white transition-colors md:text-4xl"
      href="/contato"
    >
      Entrar em contato
    </Link>
    <div class="mx-auto mt-24 grid max-w-4xl gap-12 text-left opacity-60 md:grid-cols-3">
      <div>
        <span class="mb-2 block text-xs font-bold tracking-widest uppercase">Localização</span>
        <p class="font-light">Belo Horizonte, Brasil</p>
      </div>
      <div>
        <span class="mb-2 block text-xs font-bold tracking-widest uppercase">Disponibilidade</span>
        <p class="font-light">Indisponível até dia 17/04</p>
      </div>
      <div>
        <span class="mb-2 block text-xs font-bold tracking-widest uppercase">Redes Socais</span>
        <p class="font-light">LinkedIn / GitHub</p>
      </div>
    </div>
  </div>
</section>
