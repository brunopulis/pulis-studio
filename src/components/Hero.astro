---
import { Link } from 'accessible-astro-components'
import { ArrowRight } from '@lucide/astro'
---

<section class="relative mx-auto flex min-h-[819px] max-w-7xl items-center overflow-hidden px-8 py-20">
  <div class="grid w-full items-center gap-12 md:grid-cols-12">
    <div class="space-y-8 md:col-span-8">
      <p class="text-portage-500 text-sm font-bold tracking-[0.15em] uppercase">Especialista em acessibilidade</p>
      <h1 class="text-5xl leading-tight md:text-7xl">
        Acessibilidade como <span class="text-rosewood-950 italic">convicção.</span>
      </h1>
      <p class="max-w-2xl text-xl leading-relaxed font-light text-zinc-600 md:text-2xl">
        Sou Bruno Pulis. Trabalho com acessibilidade digital e front-end para construir uma web onde a barreira técnica
        seja superada pela arquitetura da inclusão.
      </p>
      <div class="flex flex-wrap gap-4 pt-4">
        <Link
          href="/portfolio"
          class="bg-rosewood-950 hover:bg-opacity-90 focus:ring-vista-blue rounded-lg px-8 py-3 font-bold text-white transition-all focus:ring-2 focus:ring-offset-2"
        >
          Ver o que faço
        </Link>
        <Link
          href="/contato"
          class="focus:ring-vista-blue text-brand-red rounded-lg border border-zinc-300 px-8 py-3 font-bold transition-all hover:bg-zinc-50 focus:ring-2 focus:ring-offset-2"
        >
          Falar comigo
        </Link>
      </div>
    </div>
    <div class="hidden justify-end md:col-span-4 md:flex">
      <div class="bg-vista-blue h-96 w-1 opacity-50"></div>
    </div>
  </div>
</section>
