---
import { Link } from 'accessible-astro-components'
---

<section class="hero my-24">
  <div class="container">
    <div class="grid grid-cols-1 items-center gap-12">
      <div class="flex flex-col items-center gap-8 md:items-start">
        <span class="hero__label" aria-hidden="true">Belo Horizonte, Brasil</span>
        <h1 class="text-center text-6xl md:text-left lg:text-8xl">
          <slot>
            Acessibilidade<br />
            <span class="text-lead">como convicção.</span>
          </slot>
        </h1>
        <p class="hero__desc">
          Sou Bruno Pulis — especialista em acessibilidade digital com mais de uma década ajudando equipes e
          organizações a construírem produtos que funcionam para <strong>todo mundo</strong>.
        </p>
        <div class="flex flex-col gap-3 min-[500px]:flex-row">
          <Link
            href="https://github.com/incluud/accessible-astro-starter"
            isButton
            type="primary"
            animateOnHover
            animationType="boop"
          >
            Veja o que faço
          </Link>
          <Link
            href="https://accessible-astro.incluud.dev/"
            isButton
            type="secondary"
            animateOnHover
            animationType="boop"
          >
            Falar comigo
          </Link>
        </div>
      </div>
    </div>
  </div>
</section>

<style lang="scss">
  h1 {
    text-wrap: unset;
  }

  .text-lead {
    color: var(--color-rosewood-950);
  }
</style>
